{
  "id": "skill-summarize",
  "name": "Summarize",
  "description": "Summarize long text responses into concise bullet points.",
  "version": "1.0.0",
  "author": "Prism-UI Team",
  "type": "skill",
  "entry_point": "main.py",
  "hooks": ["post_receive"],
  "commands": {
    "/summarize": "handle_summarize"
